# ============================================================
# Community OS — Production Environment Variables
# ============================================================
# Copy this file to .env.production and fill in real values.
# NEVER commit .env.production to version control.

# Application
NODE_ENV=production
APP_PORT=4000
APP_URL=https://your-domain.com

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/community_os_prod

# Redis
REDIS_URL=redis://user:password@host:6379

# Authentication (MUST be strong random strings, min 32 chars)
JWT_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_STRONG_SECRET_MIN_32
ARGON2_PEPPER=REPLACE_WITH_RANDOM_16_CHARS

# SMTP (Email — use SES, SendGrid, or similar in production)
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=your-ses-smtp-user
SMTP_PASS=your-ses-smtp-password
SMTP_FROM=Community OS <noreply@your-domain.com>

# Meilisearch (optional — for full-text search)
MEILI_HOST=http://meilisearch:7700
MEILI_MASTER_KEY=your-meilisearch-master-key

# Frontend
NEXT_PUBLIC_API_URL=https://api.your-domain.com/api/v1
