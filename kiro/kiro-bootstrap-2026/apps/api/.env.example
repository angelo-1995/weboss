# ─────────────────────────────────────────────────────────────
# Community OS API — Environment Variables
# Copy this file to .env and fill in the values.
# ─────────────────────────────────────────────────────────────

# Application
# Allowed values: development, production, test
NODE_ENV=development
# Port the API server listens on (default: 3001)
APP_PORT=3001

# ─────────────────────────────────────────────────────────────
# Database
# ─────────────────────────────────────────────────────────────
# PostgreSQL connection URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/community_os_dev

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
# Redis connection URL (used for caching and session store)
REDIS_URL=redis://localhost:6379

# ─────────────────────────────────────────────────────────────
# Authentication
# ─────────────────────────────────────────────────────────────
# JWT signing secret (min 32 characters, must be strong in production)
JWT_SECRET=your-jwt-secret-at-least-32-characters-long
# JWT refresh token secret (min 32 characters, must be strong in production)
JWT_REFRESH_SECRET=your-jwt-refresh-secret-at-least-32-chars
# Token expiration durations
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────────────────────
# Encryption
# ─────────────────────────────────────────────────────────────
# Argon2 pepper for password hashing (min 16 characters, must be strong in production)
ARGON2_PEPPER=your-pepper-at-least-16-chars
# Argon2 tuning parameters
ARGON2_MEMORY_COST=65536
ARGON2_TIME_COST=3
ARGON2_PARALLELISM=4

# ─────────────────────────────────────────────────────────────
# Email (SMTP)
# ─────────────────────────────────────────────────────────────
# Maildev defaults for local development (no auth needed)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM=Community OS <noreply@communityos.app>
# SMTP_USER=  (not needed for Maildev; set for SES/SendGrid in production)
# SMTP_PASS=  (not needed for Maildev; set for SES/SendGrid in production)

# ─────────────────────────────────────────────────────────────
# Logging
# ─────────────────────────────────────────────────────────────
# Allowed values: debug, info, warn, error
LOG_LEVEL=debug
