{
  "name": "@community-os/database",
  "version": "0.1.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "pnpm exec prisma generate",
    "db:migrate": "pnpm exec prisma migrate dev",
    "db:migrate:deploy": "pnpm exec prisma migrate deploy",
    "db:seed": "tsx src/seed/index.ts",
    "db:seed:production": "tsx src/seed/production.ts",
    "db:studio": "pnpm exec prisma studio",
    "db:reset": "pnpm exec prisma migrate reset --force"
  },
  "dependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0",
    "argon2": "^0.41.0"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "@community-os/config": "workspace:*"
  }
}
